{
  "name": "lr6-variant-9-ci-cd",
  "version": "1.0.0",
  "description": "Lab 6 variant 9: CI/CD for complex automated tests",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "test:unit": "jest --config=jest.config.allure.js --runInBand",
    "test:api": "cucumber-js",
    "test:ui": "playwright test",
    "test:ui:chromium": "playwright test --project=chromium",
    "test:all": "npm run clean && npm run test:unit && npm run test:api && npm run test:ui:chromium",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "report:ui": "playwright show-report playwright-report",
    "clean": "node scripts/clean.js"
  },
  "dependencies": {
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^11.3.0",
    "@playwright/test": "^1.53.0",
    "allure-commandline": "^2.34.1",
    "allure-jest": "^3.4.1",
    "allure-playwright": "^3.4.1",
    "jest": "^29.7.0",
    "jest-html-reporters": "^3.1.7",
    "supertest": "^7.1.1",
    "wait-on": "^8.0.3"
  }
}
